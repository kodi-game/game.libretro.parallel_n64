msgid "(Glide64) Texture Filtering"
msgstr "(Glide64) Фильтрация текстур"

msgctxt "#30080"
msgid "(Angrylion) Dithering"
msgstr "(Angrylion) Дизеринг"

msgctxt "#30081"
msgid "(Glide64) Polygon Offset Factor"
msgstr "(Glide64) Коэффициент смещения полигонов"

msgctxt "#30082"
msgid "(Glide64) Polygon Offset Units"
msgstr "(Glide64) Единицы смещения полигонов"

msgctxt "#30083"
msgid "Buffer Swap"
msgstr "Замена буфера"

msgctxt "#30084"
msgid "Framerate (restart)"
msgstr "Частота кадров (перезапуск)"

msgctxt "#30085"
msgid "Independent C-button Controls"
msgstr "Независимое управление кнопками C"

msgctxt "#30086"
