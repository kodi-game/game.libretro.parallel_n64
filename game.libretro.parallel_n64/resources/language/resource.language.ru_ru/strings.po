msgstr "Включить ОЗУ Expansion Pak"

msgctxt "#30073"
msgid "GFX Accuracy (restart)"
msgstr "Точность графики (перезапуск)"

msgctxt "#30074"
msgid "Send audio lists to HLE RSP"
msgstr "Отправлять аудиосписки в HLE RSP"

msgctxt "#30075"
msgid "GFX Plugin"
msgstr "Графический плагин"

msgctxt "#30076"
msgid "RSP Plugin"
msgstr "Плагин RSP"

msgctxt "#30077"
msgid "Resolution (restart)"
msgstr "Разрешение (перезапуск)"

msgctxt "#30078"
msgid "Aspect ratio hint (reinit)"
msgstr "Подсказка соотношения сторон (реинициализация)"

