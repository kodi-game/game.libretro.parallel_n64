msgctxt "Addon Summary"
msgid "Nintendo - Nintendo 64 (ParaLLEl N64)"
msgstr "Nintendo — Nintendo 64 (ParaLLEl N64)"

msgctxt "Addon Description"
msgid "ParaLLEl N64 is an optimized/rewritten Nintendo 64 emulator based on Mupen64 Plus. It was made specifically for Libretro."
msgstr "ParaLLEl N64 — это оптимизированный/переписанный эмулятор Nintendo 64, основанный на Mupen64 Plus. Он был создан специально для Libretro."

msgctxt "#30001"
msgid "CPU Core"
msgstr "Ядро ЦП"

msgctxt "#30003"
msgid "Analog Deadzone (percent)"
msgstr "Мёртвая зона аналога (проценты)"

msgctxt "#30004"
msgid "Analog Sensitivity (percent)"
msgstr "Чувствительность аналога (проценты)"

